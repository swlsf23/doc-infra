# Copy to terraform.tfvars (gitignored) and set values before terraform apply.
# cp terraform.tfvars.example terraform.tfvars

aws_region = "us-east-1"

# Must be globally unique across all of AWS (S3 bucket DNS name).
site_bucket_name = "your-org-doc-infra-site-UNIQUE"

name_prefix = "doc-infra"

# Set true only for throwaway sandboxes so `terraform destroy` can empty the bucket.
force_destroy_bucket = false

# PriceClass_100 | PriceClass_200 | PriceClass_All
cloudfront_price_class = "PriceClass_100"
